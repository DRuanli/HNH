PTK_HUIM -- DFS version

I. Fields

a. Configuration // Input from user - immutable
- databaseFile : String {readOnly}
- profitFile : String {readOnly}
- outputFile : String {readOnly}
- k : int {readOnly}
- minProbability : double {readOnly}
- parallel : boolean {readOnly}         // Use to enable/disable parallel mode
- debug : boolean {readOnly}            // Use to enable/disable debug mode

b. Parsed Data // Compute Values
- database : List<Transaction>           // Scan from databaseFile
- profitTable : Map<Integer, Double>    // Scan from profitTable
- maxItemId : int   // Maximum ID in profitTable
- denseSize : int   // Number of actual items in data (handle spare ID)
- itemIdToDense : int[]     // Lookup table for actual id -> dense index
                            // itemIdToDense[500] -> index = 3 => Use index 3 for mining
- denseToItem : int[]       // Revise Lookup Table to find actual Id from dense idx
                            // denseIdToItem[3] -> id = 500
- profitCache : double[]    // Profit of each item by dense idx
/*
    Dense Mapping use for handle Spare data that has 5 items but the maxId can up to millions
*/
c. Phase 1 Outputs

// Using [] for essay access and can handle with Fork-Join
- densePTWU : double[]          // PTWU Map for lookup by dense idx
- denseLogComp : double[]       // Log Component by dense idx -- prevent underflow
- validItems : Set<Integer>     // Set of valid item (pruned by EP) -- use Set for O(0) access and prevent duplication
- sortedItems : List<Integer>   // List of valid item sorted by PTWU
- rankByItemId : int[]
- singleItemLists : Map<Integer, UPUList>  // UPU List of single item

/*
   validItems answer the question "Is item X valid?" when check each transaction
   sortedItems answer the question "What is the next item?" when mining in Phase 3
   rankByItemId answer the question "What is X rank?" use for build UPUList buider, reorder item in transaction

   => Use memory for getting better processing speed
*/

d. Mining Phase and Statistics
- collector : TopKCollector
- pool : ForkJoinPool
- maxMemory : double
- totalStartTime : double
- totalEndTime : double
- phase1Ms, phase2Ms, phase3Ms : double

II. Constants
- EPSILON : double {readOnly}
- LOG_ZERO : double {readOnly}
- LOG_ONE_MINUS_EPS : double {readOnly}
